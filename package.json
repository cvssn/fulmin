{
  "name": "fulmin",
  "version": "1.0.0",
  "description": "expressões regulares estendidas",
  "author": {
    "name": "cavassani"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cvssn/fulmin.git"
  },
  "keywords": [
    "regex",
    "regexp",
    "regular-expression",
    "unicode"
  ],
  "browser": "./lib/index.js",
  "main": "./lib/index.js",
  "module": "./src/index.js",
  "files": [
    "src",
    "lib",
    "tools/output",
    "fulmin-all.js",
    "types/index.d.ts"
  ],
  "scripts": {
    "lint": "eslint .",
    "babel": "babel src -d lib",
    "build-unicode-data": "node tools/scripts/category-regex.js && node tools/scripts/property-regex.js && node tools/scripts/script-regex.js",
    "prebuild": "npm run build-unicode-data && npm run lint && npm run babel",
    "build": "browserify lib/index.js --standalone Fulmin > fulmin-all.js",
    "pretest": "npm run build",
    "test": "nyc --reporter=lcov --reporter=text-summary jasmine JASMINE_CONFIG_PATH=tests/jasmine.json",
    "prepublish": "npm test"
  },
  "types": "types/index.d.ts",
  "dependencies": {
    "@babel/runtime-corejs3": "^7.29.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-unicode-property-regex": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@unicode/unicode-14.0.0": "^1.6.16",
    "babel-plugin-add-module-exports": "^1.0.4",
    "babel-plugin-transform-xregexp": "^1.0.0",
    "browserify": "^17.0.1",
    "eslint": "^10.1.0",
    "jasmine": "^6.1.0",
    "jsesc": "^3.1.0",
    "nyc": "^18.0.0",
    "unicode-property-value-aliases": "^3.9.0"
  }
}
